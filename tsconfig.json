{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "jsx": "preserve",
    "skipLibCheck": true,
    "types": ["node"],
    "paths": {
      "@/*": ["./.vitepress/*"]
    }
  },
  "include": [".vitepress/**/*.ts", ".vitepress/**/*.vue", ".vitepress/env.d.ts", "docs/**/*.data.ts"]
}
